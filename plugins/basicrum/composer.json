{
    "name": "basicrum/basicrum-wordpress",
    "description": "Basicrum - Budget, Open Source, Real User Monitoring for WordPress",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Tsvetan Stoychev",
            "homepage": "https://www.basicrum.com/contact/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1.0 || ^2.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "yoast/wp-test-utils": "^1.2",
        "php-parallel-lint/php-parallel-lint": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Basicrum\\WP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Basicrum\\WP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "lint:php": "parallel-lint --exclude vendor --exclude node_modules .",
        "unit": "phpunit",
        "integration": "phpunit --configuration phpunit-with-integration.xml",
        "coverage": "XDEBUG_MODE=coverage phpunit --coverage-clover coverage.xml"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    }
}
