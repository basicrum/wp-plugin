# Local Docker development defaults. Copy to .env to override them.
WORDPRESS_PORT=9080
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_ROOT_PASSWORD=root

WP_URL=http://localhost:9080
WP_TITLE=Basicrum Local
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=basicrum-dev-password
WP_ADMIN_EMAIL=admin@example.test
